---
const contactMethods = [
  {
    icon: "📱",
    title: "WhatsApp",
    description: "Respuesta inmediata",
    action: "+1234567890"
  },
  {
    icon: "📧",
    title: "Email",
    description: "Soporte 24/7",
    action: "contacto@devconsulting.com"
  },
  {
    icon: "📍",
    title: "Ubicación",
    description: "Oficina central",
    action: "Ciudad, País"
  }
];
---
<section id="contact" class="py-20 bg-gradient-to-br from-slate-800 via-indigo-900 to-slate-800">
  <div class="container mx-auto px-6">
    <div class="max-w-4xl mx-auto text-center mb-12">
      <h2 class="text-4xl font-bold mb-4 text-white">¿Listo para empezar?</h2>
      <p class="text-gray-300 mb-8">
        Contáctanos para discutir tu proyecto y comenzar a construir algo increíble juntos
      </p>
      <div class="grid md:grid-cols-3 gap-8 mb-12">
        {contactMethods.map(method => (
          <div class="p-6 rounded-xl bg-white/5 backdrop-blur-sm border border-white/10">
            <div class="text-4xl mb-3">{method.icon}</div>
            <h3 class="text-lg font-semibold text-white mb-1">{method.title}</h3>
            <p class="text-gray-400 text-sm mb-2">{method.description}</p>
            <p class="text-indigo-400">{method.action}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="max-w-2xl mx-auto">
      <form class="space-y-6">
        <div>
          <label class="block text-sm font-medium mb-2 text-gray-300">Nombre</label>
          <input type="text" class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/10 text-white placeholder-gray-400 focus:outline-none focus:border-indigo-500" required>
        </div>
        <div>
          <label class="block text-sm font-medium mb-2 text-gray-300">Email</label>
          <input type="email" class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/10 text-white placeholder-gray-400 focus:outline-none focus:border-indigo-500" required>
        </div>
        <div>
          <label class="block text-sm font-medium mb-2 text-gray-300">Mensaje</label>
          <textarea class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/10 text-white placeholder-gray-400 focus:outline-none focus:border-indigo-500 h-32" required></textarea>
        </div>
        <button type="submit" class="w-full bg-indigo-600 text-white py-3 rounded-lg hover:bg-indigo-700 transition-all hover:shadow-xl hover:shadow-indigo-500/20">
          Enviar mensaje
        </button>
      </form>
    </div>
    <div class="mt-12 text-center text-sm text-gray-400">
      <p>Al enviarnos tu mensaje, aceptas nuestra política de privacidad y términos de servicio.</p>
    </div>
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
</section>
