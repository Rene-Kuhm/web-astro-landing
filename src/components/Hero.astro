---
const stats = [
  { number: "+100", label: "Proyectos completados" },
  { number: "98%", label: "Clientes satisfechos" },
  { number: "+5", label: "Años de experiencia" },
  { number: "+20", label: "Tecnologías dominadas" }
];
---

<section class="relative min-h-screen bg-gradient-to-br from-slate-900 via-indigo-900 to-slate-900 parallax-container">
  <div class="parallax-layer bg-[url('/assets/grid.svg')] opacity-10" data-speed="0.5"></div>
  <div class="parallax-content">
    <div class="container mx-auto px-6 py-32 relative z-10">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="text-white space-y-8 animate-fade-in">
          <div class="inline-block px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full text-sm font-medium mb-2">
            🚀 Innovación Digital & Desarrollo
          </div>
          <h1 class="text-5xl md:text-6xl font-bold leading-tight">
            Desarrollo Web <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400">Full Stack</span> & Consultoría
          </h1>
          <p class="text-xl text-gray-300">
            Transformamos ideas en soluciones digitales innovadoras. Especialistas en desarrollo web
            y consultoría tecnológica para empresas y particulares.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="#contact" class="bg-indigo-600 text-white px-8 py-3 rounded-lg hover:bg-indigo-700 transition-all hover:shadow-xl hover:shadow-indigo-500/20">
              ¡Comenzemos tu proyecto!
            </a>
            <a href="#services" class="bg-white/10 backdrop-blur-sm text-white px-8 py-3 rounded-lg hover:bg-white/20 transition-all">
              Ver servicios
            </a>
          </div>
          <div class="flex items-center gap-8 pt-8 border-t border-white/10">
            {stats.map(stat => (
              <div class="text-center">
                <div class="text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-indigo-400">
                  {stat.number}
                </div>
                <div class="text-gray-400 text-sm">{stat.label}</div>
              </div>
            ))}
          </div>
          
          <div class="flex items-center gap-4 mt-8 bg-white/5 p-4 rounded-lg backdrop-blur-sm">
            <div class="flex -space-x-4">
              {[1,2,3].map(() => (
                <img class="w-10 h-10 rounded-full border-2 border-slate-900" src="https://api.dicebear.com/6.x/avataaars/svg?seed=Felix" alt="User Avatar" />
              ))}
            </div>
            <p class="text-sm text-gray-300">
              +50 empresas confían en nosotros para sus soluciones digitales
            </p>
          </div>
        </div>
        <div class="relative">
          <div class="relative z-10 animate-float">
            <img 
              src="/assets/hero.png" 
              alt="Development illustration" 
              class="w-full h-auto max-w-lg mx-auto drop-shadow-2xl"
            >
          </div>
          <div class="absolute inset-0 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-full filter blur-[100px] opacity-30 animate-pulse"></div>
        </div>
      </div>
    </div>
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
</section>

<style>
  .parallax-container {
    overflow: hidden;
    position: relative;
  }
  
  .parallax-layer {
    position: absolute;
    inset: -20%;
    will-change: transform;
  }
  
  .parallax-content {
    position: relative;
    z-index: 1;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
  }
</style>
