---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sobre Nosotros - DevConsulting">
  <section class="py-32 bg-white">
    <div class="container mx-auto px-6">
      <h1 class="text-4xl font-bold mb-8">Sobre Nosotros</h1>
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <img 
            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800" 
            alt="Equipo de trabajo" 
            class="rounded-lg shadow-lg"
          >
        </div>
        <div>
          <h2 class="text-2xl font-semibold mb-4">Nuestra Misión</h2>
          <p class="text-gray-600 mb-6">
            Ayudamos a empresas y emprendedores a alcanzar su máximo potencial digital a través de soluciones tecnológicas innovadoras y consultoría especializada.
          </p>
          <h2 class="text-2xl font-semibold mb-4">Nuestra Experiencia</h2>
          <p class="text-gray-600">
            Con más de 5 años de experiencia en el sector, hemos ayudado a más de 100 clientes a transformar sus ideas en productos digitales exitosos.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
