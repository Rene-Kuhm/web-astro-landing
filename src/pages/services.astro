---
import Layout from '../layouts/Layout.astro';
import Services from '../components/Services.astro';
---

<Layout title="Servicios - DevConsulting">
  <section class="py-32">
    <div class="container mx-auto px-6">
      <h1 class="text-4xl font-bold mb-12 text-center">Nuestros Servicios</h1>
      <Services />
      <div class="mt-16 text-center">
        <h2 class="text-2xl font-semibold mb-8">¿Por qué elegirnos?</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="p-6">
            <div class="text-4xl mb-4">🚀</div>
            <h3 class="text-xl font-semibold mb-2">Entrega Rápida</h3>
            <p class="text-gray-600">Resultados eficientes y a tiempo</p>
          </div>
          <div class="p-6">
            <div class="text-4xl mb-4">💡</div>
            <h3 class="text-xl font-semibold mb-2">Soluciones Innovadoras</h3>
            <p class="text-gray-600">Usando las últimas tecnologías</p>
          </div>
          <div class="p-6">
            <div class="text-4xl mb-4">🤝</div>
            <h3 class="text-xl font-semibold mb-2">Soporte Continuo</h3>
            <p class="text-gray-600">Acompañamiento post-proyecto</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
