---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: "E-commerce Platform",
    description: "Plataforma de comercio electrónico moderna",
    image: "https://images.unsplash.com/photo-1661961112951-f2bfd1f253ce?auto=format&fit=crop&w=800",
    technologies: ["React", "Node.js", "MongoDB"]
  },
  {
    title: "Dashboard Analytics",
    description: "Sistema de análisis de datos empresariales",
    image: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800",
    technologies: ["Vue.js", "Python", "PostgreSQL"]
  },
  {
    title: "Mobile App",
    description: "Aplicación móvil para gestión de tareas",
    image: "https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?auto=format&fit=crop&w=800",
    technologies: ["React Native", "Firebase"]
  }
];
---

<Layout title="Proyectos - DevConsulting">
  <section class="py-32 bg-gray-50">
    <div class="container mx-auto px-6">
      <h1 class="text-4xl font-bold mb-12 text-center">Nuestros Proyectos</h1>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map(project => (
          <div class="bg-white rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition">
            <img src={project.image} alt={project.title} class="w-full h-48 object-cover">
            <div class="p-6">
              <h3 class="text-xl font-semibold mb-2">{project.title}</h3>
              <p class="text-gray-600 mb-4">{project.description}</p>
              <div class="flex flex-wrap gap-2">
                {project.technologies.map(tech => (
                  <span class="px-3 py-1 bg-indigo-100 text-indigo-600 rounded-full text-sm">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
